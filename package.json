{
  "name": "odin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --build",
    "lint": "eslint . && depcruise --config .dependency-cruiser.json src",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/core": "8.4.1",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@fast-check/vitest": "0.4.1",
    "@pinia/testing": "1.0.3",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/test-utils": "2.4.11",
    "dependency-cruiser": "18.0.0",
    "eslint": "10.7.0",
    "eslint-plugin-vue": "10.9.2",
    "fast-check": "4.9.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.26.0",
    "lint-staged": "17.0.8",
    "postcss-html": "1.8.1",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix",
      "prettier --write",
      "stylelint --fix"
    ],
    "*.css": [
      "stylelint --fix"
    ]
  }
}
